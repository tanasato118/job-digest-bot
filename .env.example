DISCORD_WEBHOOK_URL=
MIN_BUDGET_JPY=3000
KEYWORDS=Dify,ChatGPT,GPTs,プロンプト,Python,自動化,TradingView,AI,チャットボット,業務効率化,WordPress,LP制作,スプレッドシート,GAS,Excel,CSV,データ整理,データ入力,AI活用,AI導入,生成AI,RAG,bot構築,スクリプト作成,ツール作成,業務改善
PREFER_BEGINNER_FRIENDLY=true
TOP_N=15

# スキルマッチ用キーワード（案件の skills フィールドとマッチ）
SKILLS=Python,Dify,ChatGPT,WordPress,TradingView,GAS,Excel,AI

# スコアリング重み設定
# 形式: ルール名:重み をカンマ区切り。0にすると無効化。省略するとデフォルト値を使用。
# 利用可能なルール:
#   keyword          — タイトル・説明文のキーワードマッチ（デフォルト: 60）
#   budget           — 最低単価以上（デフォルト: 20）
#   beginnerFriendly — 初心者歓迎案件を優先（デフォルト: 25）
#   lowCompetition   — 応募人数が少ない案件を優先（デフォルト: 15）
#   clientRating     — クライアント評価が高い（デフォルト: 15）
#   clientJobCount   — クライアント発注実績が多い（デフォルト: 10）
#   deadlineMargin   — 締切まで余裕がある（デフォルト: 10）
#   recency          — 新着案件を優先（デフォルト: 10）
#   skillMatch       — 必要スキルとのマッチ（デフォルト: 20）
#
# 例: キーワードと予算だけで判定し、初心者歓迎を無効化
# SCORING_WEIGHTS=keyword:80,budget:30,beginnerFriendly:0
SCORING_WEIGHTS=

# スコアリング閾値
LOW_COMPETITION_THRESHOLD=10
DEADLINE_MARGIN_DAYS=7
RECENCY_DAYS=3
MIN_CLIENT_RATING=4.0
MIN_CLIENT_JOB_COUNT=5

# ソース有効/無効（デフォルトはすべて有効）
ENABLE_CROWDWORKS=true
ENABLE_LANCERS=true
ENABLE_COCONALA=true

# Letta API（メモリ・スコアリング判定）
# https://www.letta.com から取得
LETTA_API_URL=https://api.letta.com
LETTA_API_KEY=your_letta_api_key_here
LETTA_AGENT_ID=your_letta_agent_id_here
